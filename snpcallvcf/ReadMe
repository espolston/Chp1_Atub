#Running gatk bc freebayes was taking so long
#GATK - version 4.6.2
#Run on each individual for gvcf, then on each region

#Download and install gatk
#module load python/anaconda-2023.09
#module load apptainer 
#apptainer pull gatk_4.6.2.0.sif docker://broadinstitute/gatk:4.6.2.0
#need to run gatk like this: apptainer exec gatk_4.6.2.0.sif gatk HaplotypeCaller

#Copy bams to scratch
bams.sbatch

#make regions file (col1: bam name (not bamfile, no .bam), col2: renamed sample ex: AT1_10	P4_Ag_4_T) "*_193_2.dd.bam"
bams_samplenames.txt #2 indivs to remove have been (from metadata)
#add duplicate marked bam extension to col 1 "*_193_2.sort.dd.bam" 
awk '{OFS="\t"; $3 = $1"_193_2.dd.bam"; print $3,$2}' bam_samplenames.txt > bamsdone_samplenames.txt
#Make sample only file
awk '{OFS="\t"; print $1}' /scratch/midway3/espolston/bam_samplenames.txt > /scratch/midway3/espolston/bam_locations.txt
#Make final sample names only file
awk '{OFS="\t"; print $2}' /scratch/midway3/espolston/bam_samplenames.txt > /scratch/midway3/espolston/gvcf_names.txt

#make regions file for vcf stage
#get fasta_generate_regions.py from https://github.com/freebayes/freebayes/blob/master/scripts/fasta_generate_regions.py 
python3 fasta_generate_regions.py Atub_193_hap2.fasta 100000 > 100kbregions
#fixing regions to be 1 start for gatk
awk '{OFS="\t"; split($1, part, ":"); $2=part[1]; $3=part[2]; split($3, region,"-"); $4=region[1]+1; $5=region[2]; $6=$2":"$4"-"$5; print $6}' /scratch/midway3/espolston/100kbregions > /scratch/midway3/espolston/final
awk '{OFS="\t"; split($1, array, "."); $4=array[1]".dd.bam"; split($3, part, ":"); $5=part[1]; $6=part[2]; split($6, region,"-"); $7=region[1]+1; $8=region[2]; $9=$5":"$7"-"$8; print $4,$2,$9}' /scratch/midway3/espolston/100kbregions_wnames.txt > /scratch/midway3/espolston/test.txt
#sorting 100kbregions by scaffold and regions start
awk '{OFS="\t"; split($1, part, ":"); $2=part[1]; $3=part[2]; split($2, scaf, "_"); $4= scaf[2]; split($3, region, "-"); $5=region[1]; print $1,$4,$5}' /scratch/midway3/espolston/100kbregions > /scratch/midway3/espolston/final
sort -k2,2n -k3,3n final > final_sort.txt
awk '{OFS="\t"; print $1}' final_sort.txt > 100kbregions

#From here following julia's tutorial: https://ubcforestrybioinformatics.github.io/pages/topic_7/topic_7/ 
#create sequence dictionary
apptainer exec /project/kreiner/espolston/gatk_4.6.2.0.sif gatk CreateSequenceDictionary \
  -R /scratch/midway3/espolston/Atub_193_hap2.fasta \
  -O /scratch/midway3/espolston/Atub_193_hap2.dict

#Bams already checked for duplicate reads -- samtools stats BAMFILE confirmed
  
#run on indiv bam and renames drought samples
gatk_indivvar.sbatch
2_bamvariantcall.sh #creates failed regions file to start next run
3_bamvariantcall.sbatch





